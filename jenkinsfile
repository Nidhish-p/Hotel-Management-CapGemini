pipeline {
    agent any

    environment {
        DB_URL = "jdbc:mysql://172.16.160.104:3306/dummy_hotel"
        DB_USERNAME = "groupuser"
        DB_PASSWORD = "Strong@123"
    }

    stages {

        stage('Build') {
            steps {
                bat 'mvn clean install'
            }
        }

        stage('Run App') {
            steps {
                bat 'java -jar target/*.jar'
            }
        }
    }
}